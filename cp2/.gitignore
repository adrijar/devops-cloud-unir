# ============================================================
# .gitignore — Caso Practico 2 (DevOps & Cloud, UNIR)
# ============================================================

# ----- Terraform -----
.terraform/
terraform.tfstate
terraform.tfstate.backup
crash.log
*.tfvars
*.tfvars.json
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ----- Ansible -----
# El fichero hosts se genera dinamicamente por deploy-all.sh
# y contiene credenciales del ACR. No versionar.
ansible/hosts
*.retry
ansible.log
.vault_pass
.vault_password

# ----- SSH y credenciales -----
*.pem
*.key
id_rsa
id_ed25519
cp2_key
!*.pub
.env
.env.local
secrets.yml
credentials.json

# ----- Sistema operativo -----
Thumbs.db
desktop.ini
.DS_Store
*~
.directory

# ----- Editores -----
.vscode/
.idea/
*.swp
*.swo
*.bak
*.tmp
*.cache
