pipeline {
    agent none

    stages {

        stage('Get Code') {
            agent { label 'principal' }
            steps {
                git 'https://github.com/adrijar/devops-cloud-unir.git'
                sh 'whoami && hostname && echo WORKSPACE=$WORKSPACE'
            }
        }

        stage('Tests') {
            parallel {

                stage('Unit') {
                    agent { label 'principal' }
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami && hostname && echo WORKSPACE=$WORKSPACE
                                export PYTHONPATH=$WORKSPACE/cp1.2
                                pytest --junitxml=result-unit.xml cp1.2/test/unit
                            '''
                        }
                    }
                    post {
                        always {
                            junit 'result-unit.xml'
                        }
                    }
                }

                stage('Rest') {
                    agent { label 'principal' }
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami && hostname && echo WORKSPACE=$WORKSPACE
                                export FLASK_APP=cp1.2/app/api.py
                                export FLASK_ENV=development
                                flask run &
                                java -jar /tmp/wiremock.jar --port 9090 --root-dir cp1.2/test/wiremock &
                                sleep 8
                                export PYTHONPATH=$WORKSPACE/cp1.2
                                pytest --junitxml=result-rest.xml cp1.2/test/rest
                            '''
                        }
                    }
                    post {
                        always {
                            junit 'result-rest.xml'
                        }
                    }
                }

                stage('Static') {
                    agent { label 'node1' }
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami && hostname && echo WORKSPACE=$WORKSPACE
                                flake8 --format=pylint --exit-zero cp1.2/app > flake8.out
                            '''
                        }
                    }
                    post {
                        always {
                            recordIssues qualityGates: [[threshold: 8, type: 'TOTAL', unstable: true], [threshold: 10, type: 'TOTAL', unstable: false]], tools: [flake8(pattern: 'flake8.out')]
                        }
                    }
                }

                stage('Security') {
                    agent { label 'node1' }
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami && hostname && echo WORKSPACE=$WORKSPACE
                                bandit -r cp1.2/app -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}" --exit-zero
                            '''
                        }
                    }
                    post {
                        always {
                            recordIssues qualityGates: [[threshold: 2, type: 'TOTAL', unstable: true], [threshold: 4, type: 'TOTAL', unstable: false]], tools: [pyLint(pattern: 'bandit.out')]
                        }
                    }
                }
            }
        }

        stage('Coverage') {
            agent { label 'principal' }
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                        whoami && hostname && echo WORKSPACE=$WORKSPACE
                        export PYTHONPATH=$WORKSPACE/cp1.2
                        coverage run --source=cp1.2/app --branch -m pytest cp1.2/test/unit
                        coverage xml
                    '''
                }
            }
post {
    always {
        publishCoverage adapters: [coberturaAdapter(
            path: 'coverage.xml',
            thresholds: [[thresholdTarget: 'Line', unhealthyThreshold: 85.0, unstableThreshold: 95.0]]
        )], sourceFileResolver: sourceFiles('NEVER_STORE'),
        failNoReports: false,
        failUnhealthy: false,
        failUnstable: false
    }
}
        }

        stage('Performance') {
            agent { label 'node2' }
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                        whoami && hostname && echo WORKSPACE=$WORKSPACE
                        export FLASK_APP=cp1.2/app/api.py
                        fuser -k 5000/tcp || true
                        sleep 2
                        flask run &
                        sleep 3
                        export JVM_ARGS="-Xms256m -Xmx512m"
                        jmeter -n -t cp1.2/test/jmeter/flask.jmx -l flask.jtl
                    '''
                }
            }
            post {
                always {
                    perfReport sourceDataFiles: 'flask.jtl'
                }
            }
        }
    }

    post {
        always {
            node('principal') {
                cleanWs()
            }
        }
    }
}