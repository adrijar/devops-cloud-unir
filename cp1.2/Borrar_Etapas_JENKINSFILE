pipeline {
    agent any

    stages {

        // IGUAL QUE ANTES pero apuntando a TU repo
        stage('Get Code') {
            steps {
                git 'https://github.com/adrijar/devops-cloud-unir.git'
            }
        }

        // IGUAL pero cambiado bat por sh y dir por ls
        stage('Build') {
            steps {
                echo 'Esto es Python, no hay que compilar nada!'
                sh 'ls -la'
            }
        }

        stage('Tests') {
            parallel {

                // IGUAL pero sh en vez de bat y rutas Linux
                stage('Unit') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                export PYTHONPATH=$WORKSPACE/cp1.2
                                pytest --junitxml=result-unit.xml cp1.2/test/unit
                            '''
                        }
                    }
                }

                // IGUAL pero sh, flask y wiremock en Linux
                stage('Rest') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                export FLASK_APP=cp1.2/app/api.py
                                export FLASK_ENV=development
                                flask run &
                                java -jar /tmp/wiremock.jar --port 9090 --root-dir cp1.2/test/wiremock &
                                sleep 5
                                export PYTHONPATH=$WORKSPACE/cp1.2
                                pytest --junitxml=result-rest.xml cp1.2/test/rest
                            '''
                        }
                    }
                }

                // NUEVO: análisis estático con Flake8
                stage('Static') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'flake8 --format=pylint --exit-zero cp1.2/app > flake8.out'
                        }
                    }
                }

                // NUEVO: análisis de seguridad con Bandit
                stage('Security') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'bandit -r cp1.2/app -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}" --exit-zero'
                        }
                    }
                }
            }
        }

        // NUEVO: cobertura de código
        stage('Coverage') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                        export PYTHONPATH=$WORKSPACE/cp1.2
                        coverage run --source=cp1.2/app --branch -m pytest cp1.2/test/unit
                        coverage xml
                    '''
                }
            }
        }

        // NUEVO: pruebas de rendimiento con JMeter
        stage('Performance') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                        export FLASK_APP=cp1.2/app/api.py
                        fuser -k 5000/tcp || true
                        sleep 2
                        flask run &
                        sleep 3
                        jmeter -n -t cp1.2/test/jmeter/flask.jmx -l flask.jtl
                    '''
                }
            }
        }

        // AMPLIADO: ahora publica resultados de todos los plugins
        stage('Results') {
            steps {
                junit 'result*.xml'
                recordIssues tools: [flake8(pattern: 'flake8.out'), pyLint(pattern: 'bandit.out')]
                publishCoverage adapters: [coberturaAdapter('coverage.xml')], sourceFileResolver: sourceFiles('NEVER_STORE')
                recordIssues tools: [flake8(pattern: 'flake8.out'), pyLint(pattern: 'bandit.out')]
                perfReport sourceDataFiles: 'flask.jtl'
            }
        }
    }
}